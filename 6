<script>
const SK = 'cc_v2';
const load = () => { try { return JSON.parse(localStorage.getItem(SK)) || {}; } catch { return {}; } };
const save = s => { try { localStorage.setItem(SK, JSON.stringify(s)); } catch(e) {} };

const PAGES = {
  overview: { title:'Dashboard',      sub:'Everything in one place' },
  rapclass: { title:'RAPCLASS',       sub:'Platform build · curriculum · beta artists' },
  radio:    { title:'RAPDAD Radio',   sub:'Edit queue · interview pipeline' },
  employee: { title:'RAPDAD Employee',sub:'Client work · pricing cards' },
  sgauge:   { title:'5Gauge',         sub:'Music · brand · shows' },
  brandbible:{ title:'Brand Bible',    sub:'SGauge artist identity & visual direction' },
  insider:  { title:'Insider Circle', sub:'Founding supporter campaign · album release' },
  content:  { title:'Content',        sub:'Non-radio content queue' },
  admin:    { title:'Admin',          sub:'Life ops · people' },
  weekly:   { title:'Weekly Focus',   sub:'Intention · daily blocks · review' },
  budget:   { title:'Budget',         sub:'Income · expenses · debt' },
};

const SECTIONS = [
  { id:'rapclass', label:'RAPCLASS',      color:'var(--blue)',   keys:['rc_1','rc_2','rc_3','rc_4','rc_5','rc_6','rc_7','rc_8','rc_9','rc_10','rc_11','rc_12','rc_hyp','rc_tef','rc_nikki','rc_4th','rc_grant_research','rc_grant_apply','rc_grant_followup'] },
  { id:'radio',    label:'RAPDAD Radio',  color:'var(--pink)',   keys:['rd_roundtable','rd_kmac','rd_carrie','rd_loralee','rd_dank','rd_dimedee','rd_2eazy','rd_roman','rd_jenae'] },
  { id:'employee', label:'RD Employee',   color:'var(--orange)', keys:['emp_nakai1','emp_nakai2','emp_flost','emp_tokerfest','emp_2eazy_shoot','emp_kooya','emp_birthday','pc_mini','pc_recording','pc_fullprod','pc_mv','pc_shortform','pc_interviews','pc_event','pc_photo','pc_dev'] },
  { id:'sgauge',   label:'5Gauge',        color:'var(--purple)', keys:['sg_rec','sg_seif','sg_ego','sg_barbers','sg_sync','sg_hair','sg_videos','sg_cover','sg_brand','sg_insider','sg_bandcamp','sg_qoncert','sg_plod'] },
  { id:'content',  label:'Content',       color:'var(--yellow)', keys:['con_roundtable','con_album','con_ralfy','con_420','con_bangz'] },
