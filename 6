<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CMD CENTER</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
<style>
:root {
  --black:    #0a0a0a;
  --surface:  #111111;
  --s2:       #1a1a1a;
  --s3:       #242424;
  --s4:       #2e2e2e;
  --s5:       #3d3d3d;
  --muted:    #666;
  --dim:      #999;
  --soft:     #c8c8c8;
  --white:    #f0efe9;
  --yellow:   #F5C842; --yellow-d:#b8941f; --yellow-bg:#1e1900;
  --blue:     #3B8EEA; --blue-d:#1a5faa;   --blue-bg:#061528;
  --pink:     #E8527A; --pink-d:#b03058;   --pink-bg:#200a10;
  --purple:   #9D6FF5; --purple-d:#6535c8; --purple-bg:#110a24;
  --green:    #2ECC71; --green-d:#1a8a4a;  --green-bg:#071a0e;
  --orange:   #F0892A; --orange-d:#b05c10; --orange-bg:#1c0e00;
  --r:8px; --r-sm:5px; --sbw:230px;
  --font-d:'Bebas Neue',sans-serif; --font:'DM Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;background:var(--black);color:var(--white);font-family:var(--font);font-size:14px;line-height:1.6;}
input,textarea,button{font-family:var(--font);font-size:13px;}
button{cursor:pointer;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--s5);border-radius:2px;}

/* ── SHELL ── */
.app{display:flex;height:100vh;}

/* ── SIDEBAR ── */
.sidebar{
  width:var(--sbw);background:var(--surface);
  border-right:1px solid var(--s3);
  display:flex;flex-direction:column;flex-shrink:0;
  overflow:hidden;transition:width .25s cubic-bezier(.4,0,.2,1);
  position:relative;z-index:10;
}
.sidebar.closed{width:52px;}
.sb-toggle{
  position:absolute;top:14px;right:10px;
  width:28px;height:28px;background:var(--s3);
  border:none;border-radius:var(--r-sm);
  color:var(--dim);display:flex;align-items:center;justify-content:center;
  font-size:16px;transition:color .15s,background .15s;z-index:2;
}
.sb-toggle:hover{background:var(--s4);color:var(--white);}

.sb-logo{
  padding:16px 14px 14px;border-bottom:1px solid var(--s3);
  overflow:hidden;white-space:nowrap;
  min-height:64px;display:flex;align-items:center;gap:10px;flex-shrink:0;
}
.sb-icon{
  width:28px;height:28px;background:var(--s3);border-radius:var(--r-sm);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font-d);font-size:13px;color:var(--white);flex-shrink:0;
}
.sb-text{overflow:hidden;}
.sb-text h1{font-family:var(--font-d);font-size:18px;letter-spacing:.06em;line-height:1;color:var(--white);}
.sb-text p{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:2px;}
.closed .sb-text{display:none;}

.sb-nav{flex:1;overflow-y:auto;padding:10px 8px;}
.sb-glabel{
  font-size:9px;font-weight:700;text-transform:uppercase;
  letter-spacing:.12em;color:var(--muted);
  padding:8px 8px 4px;white-space:nowrap;overflow:hidden;
}
.closed .sb-glabel{opacity:0;pointer-events:none;}

.nb{
  display:flex;align-items:center;gap:10px;width:100%;
  padding:8px 10px;border-radius:var(--r-sm);border:none;
  background:none;color:var(--dim);font-size:13px;font-weight:400;
  text-align:left;cursor:pointer;white-space:nowrap;overflow:hidden;
  transition:background .12s,color .12s;
}
.nb:hover{background:var(--s3);color:var(--soft);}
.nb.active{background:var(--s3);color:var(--white);font-weight:500;}
.nd{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.nb .cb{
  margin-left:auto;font-size:10px;font-weight:700;
  min-width:18px;height:18px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;
  padding:0 5px;flex-shrink:0;
}
.closed .nb{padding:8px;justify-content:center;}
.closed .nl,.closed .cb{display:none;}

.sb-bot{
  padding:12px 10px;border-top:1px solid var(--s3);
  flex-shrink:0;overflow:hidden;white-space:nowrap;
}
.sb-meta{font-size:11px;color:var(--muted);padding:0 2px;}
.npill{
  display:inline-flex;align-items:center;gap:5px;margin-top:6px;
  padding:3px 9px;border-radius:4px;font-size:11px;font-weight:500;
}
.save-row{display:flex;align-items:center;gap:8px;margin-top:10px;}
.sf{font-size:10px;color:var(--green);opacity:0;transition:opacity .3s;flex:1;}
.rb{font-size:10px;color:var(--muted);background:none;border:1px solid var(--s4);border-radius:4px;padding:2px 8px;}
.rb:hover{color:var(--soft);border-color:var(--s5);}
.closed .sb-meta,.closed .npill{display:none;}
.closed .save-row{justify-content:center;}
.closed .sf,.closed .rb{display:none;}

/* ── MAIN ── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.topbar{
  display:flex;align-items:center;gap:16px;
  padding:16px 28px;border-bottom:1px solid var(--s3);flex-shrink:0;
}
.tb-left{flex:1;}
.tb-title{font-family:var(--font-d);font-size:32px;letter-spacing:.04em;line-height:1;}
.tb-sub{font-size:11px;color:var(--muted);margin-top:2px;}
.tb-right{text-align:right;font-size:11px;color:var(--muted);line-height:1.6;}

/* week strip */
.wstrip{
  display:grid;grid-template-columns:repeat(7,1fr);gap:5px;
  padding:12px 28px;border-bottom:1px solid var(--s3);flex-shrink:0;
}
.wd{
  background:var(--surface);border:1px solid var(--s3);
  border-radius:var(--r-sm);padding:7px 5px;text-align:center;
}
.wd.today{border-color:var(--green);}
.wd.nellie{border-color:var(--yellow);background:var(--yellow-bg);}
.wdn{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);}
.wd.today .wdn{color:var(--green);} .wd.nellie .wdn{color:var(--yellow);}
.wdnum{font-family:var(--font-d);font-size:20px;color:var(--white);}
.wdtag{font-size:9px;margin-top:2px;padding:1px 5px;border-radius:3px;display:inline-block;}
.tw{background:var(--green-bg);color:var(--green);}
.tn{background:var(--yellow-bg);color:var(--yellow);}
.to{background:var(--s3);color:var(--muted);}

/* panels */
.content{flex:1;overflow-y:auto;}
.panel{display:none;padding:20px 28px 40px;}
.panel.active{display:block;animation:up .18s ease;}
@keyframes up{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--s3);border-radius:var(--r);padding:18px;margin-bottom:12px;}
.card.ab{border-left:3px solid var(--blue);}
.card.ay{border-left:3px solid var(--yellow);}
.card.ap{border-left:3px solid var(--pink);}
.card.av{border-left:3px solid var(--purple);}
.card.ag{border-left:3px solid var(--green);}
.card.ao{border-left:3px solid var(--orange);}

.ch{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.ch h2{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--soft);}
.cbg{margin-left:auto;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:2px 7px;border-radius:3px;}
.cbg-b{background:var(--blue-bg);color:var(--blue);}
.cbg-y{background:var(--yellow-bg);color:var(--yellow);}
.cbg-p{background:var(--pink-bg);color:var(--pink);}
.cbg-v{background:var(--purple-bg);color:var(--purple);}
.cbg-g{background:var(--green-bg);color:var(--green);}
.cbg-o{background:var(--orange-bg);color:var(--orange);}
.cbg-x{background:var(--s3);color:var(--muted);}

.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}

/* checklist */
.cl{list-style:none;}
.cl li{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-bottom:1px solid var(--s3);}
.cl li:last-child{border-bottom:none;}
.cl li input[type="checkbox"]{margin-top:3px;width:14px;height:14px;flex-shrink:0;accent-color:var(--green);cursor:pointer;}
.cl label{cursor:pointer;color:var(--soft);line-height:1.4;font-size:13px;}
.cl label .note{font-size:11px;color:var(--muted);display:block;margin-top:1px;font-style:italic;}
.cl li.done label{text-decoration:line-through;color:var(--muted);}
.ptag{margin-left:auto;font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;flex-shrink:0;align-self:center;text-transform:uppercase;letter-spacing:.05em;}
.ptag-h{background:var(--pink-bg);color:var(--pink);}
.ptag-n{background:var(--orange-bg);color:var(--orange);}
.ptag-s{background:var(--blue-bg);color:var(--blue);}

/* fields */
.fl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--muted);margin-bottom:5px;}
.fg{margin-bottom:12px;} .fg:last-child{margin-bottom:0;}
input[type="text"],input[type="number"],textarea{
  width:100%;background:var(--s2);border:1px solid var(--s4);
  border-radius:var(--r-sm);padding:8px 11px;color:var(--white);
  outline:none;transition:border-color .15s;resize:vertical;
}
input[type="text"]:focus,input[type="number"]:focus,textarea:focus{border-color:var(--s5);}
textarea{min-height:72px;}
input.bare{background:none;border:none;padding:0;color:var(--white);font-size:22px;font-weight:500;}
input.bare:focus{outline:none;}

/* metrics */
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:8px;margin-bottom:12px;}
.metric{background:var(--s2);border-radius:var(--r-sm);padding:11px 13px;}
.ml{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:3px;}
.mv{font-size:20px;font-weight:500;}
.ms{font-size:11px;color:var(--muted);margin-top:1px;}

/* progress */
.prog{margin-bottom:10px;} .prog:last-child{margin-bottom:0;}
.ph{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}
.pn{font-size:12px;color:var(--soft);}
.pp{display:flex;align-items:center;gap:3px;}
.pp input{width:38px;background:none;border:none;color:var(--muted);font-size:11px;text-align:right;padding:0;}
.pp input:focus{outline:none;}
.pp span{font-size:11px;color:var(--muted);}
.bt{height:3px;background:var(--s3);border-radius:2px;overflow:hidden;}
.bf{height:100%;border-radius:2px;transition:width .3s;}

/* priority */
.pl{list-style:none;}
.pr{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(--s3);}
.pr:last-child{border-bottom:none;}
.pnum{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;}
.pr input{flex:1;background:none;border:none;color:var(--white);font-size:13px;padding:0;}
.pr input::placeholder{color:var(--muted);}
.pr input:focus{outline:none;}

/* budget */
.bl{list-style:none;}
.br{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--s3);font-size:13px;}
.br:last-child{border-bottom:none;}
.bc{color:var(--muted);}
.ba input{width:80px;text-align:right;background:none;border:none;color:var(--white);font-weight:500;padding:0;}
.ba input:focus{outline:none;}
.btot{display:flex;justify-content:space-between;padding-top:9px;font-size:13px;font-weight:600;border-top:1px solid var(--s4);margin-top:4px;}

/* income */
.ir{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--s3);}
.ir:last-child{border-bottom:none;}
.irlb{font-size:13px;color:var(--muted);flex:1;}
.irv{display:flex;align-items:center;gap:3px;color:var(--muted);font-size:13px;}
.irv input{width:88px;text-align:right;}

/* divider */
.sdiv{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);padding-bottom:7px;margin:18px 0 10px;border-bottom:1px solid var(--s3);}

/* day blocks */
.db{background:var(--surface);border:1px solid var(--s3);border-radius:var(--r);padding:13px 15px;margin-bottom:9px;}
.db h3{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:9px;}
.chips{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:9px;}
.chip{font-size:10px;font-weight:500;padding:3px 8px;border-radius:3px;}
.cy{background:var(--yellow-bg);color:var(--yellow);}
.cb2{background:var(--blue-bg);color:var(--blue);}
.cp{background:var(--pink-bg);color:var(--pink);}
.cv{background:var(--purple-bg);color:var(--purple);}
.cn{background:var(--s3);color:var(--muted);}

/* summary */
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:16px;}
.sc{background:var(--s2);border-radius:var(--r);padding:14px 16px;border:1px solid var(--s3);}
.sclb{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;}
.scdn{font-size:22px;font-weight:500;}
.sctt{font-size:12px;color:var(--muted);}
.scbar{height:3px;background:var(--s3);border-radius:2px;margin-top:8px;overflow:hidden;}
.scfill{height:100%;border-radius:2px;}

/* link row */
.lrow{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--s3);font-size:13px;}
.lrow:last-child{border-bottom:none;}
.lrow a{color:var(--blue);text-decoration:none;font-size:12px;}
.lrow a:hover{text-decoration:underline;}
.lnote{color:var(--muted);font-size:11px;flex:1;}
</style>
</head>
<body>
<div class="app">

<!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
<aside class="sidebar closed" id="sidebar">
  <button class="sb-toggle" onclick="toggleSB()" title="Toggle sidebar">&#8942;</button>
  <div class="sb-logo">
    <div class="sb-icon">CC</div>
    <div class="sb-text"><h1>CMD CTR</h1><p>Career OS</p></div>
  </div>
  <nav class="sb-nav">
    <div class="sb-glabel">Overview</div>
    <button class="nb active" onclick="go('overview')"><span class="nd" style="background:var(--white)"></span><span class="nl">Dashboard</span></button>

    <div class="sb-glabel">Pillars</div>
    <button class="nb" onclick="go('rapclass')"><span class="nd" style="background:var(--blue)"></span><span class="nl">RAPCLASS</span><span class="cb cbg-b" id="cnt-rapclass"></span></button>
    <button class="nb" onclick="go('radio')"><span class="nd" style="background:var(--pink)"></span><span class="nl">RAPDAD Radio</span><span class="cb cbg-p" id="cnt-radio"></span></button>
    <button class="nb" onclick="go('employee')"><span class="nd" style="background:var(--orange)"></span><span class="nl">RAPDAD Employee</span><span class="cb cbg-o" id="cnt-employee"></span></button>
    <button class="nb" onclick="go('sgauge')"><span class="nd" style="background:var(--purple)"></span><span class="nl">5Gauge</span><span class="cb cbg-v" id="cnt-sgauge"></span></button>
    <button class="nb" onclick="go('brandbible')"><span class="nd" style="background:var(--orange)"></span><span class="nl">Brand Bible</span></button>
    <button class="nb" onclick="go('insider')"><span class="nd" style="background:var(--green)"></span><span class="nl">Insider Circle</span></button>

    <div class="sb-glabel">Operations</div>
    <button class="nb" onclick="go('content')"><span class="nd" style="background:var(--yellow)"></span><span class="nl">Content</span><span class="cb cbg-y" id="cnt-content"></span></button>
    <button class="nb" onclick="go('admin')"><span class="nd" style="background:var(--green)"></span><span class="nl">Admin</span><span class="cb cbg-g" id="cnt-admin"></span></button>
    <button class="nb" onclick="go('weekly')"><span class="nd" style="background:var(--muted)"></span><span class="nl">Weekly Focus</span></button>
    <button class="nb" onclick="go('budget')"><span class="nd" style="background:var(--muted)"></span><span class="nl">Budget</span></button>
  </nav>
  <div class="sb-bot">
    <div class="sb-meta" id="wklabel">Week of —</div>
    <div id="npillwrap"></div>
    <div class="save-row">
      <span class="sf" id="saveflash">&#10003; saved</span>
      <button class="rb" onclick="resetAll()">reset</button>
    </div>
  </div>
</aside>

<!-- ══ MAIN ════════════════════════════════════════════════════ -->
<main class="main">
  <div class="topbar">
    <div class="tb-left">
      <div class="tb-title" id="ptitle">Dashboard</div>
      <div class="tb-sub" id="psub">Everything in one place</div>
    </div>
    <div class="tb-right" id="datedisp"></div>
  </div>

  <div class="wstrip" id="wstrip"></div>

  <div class="content">

    <!-- ═ OVERVIEW ════════════════════════════════════════════ -->
    <div class="panel active" id="panel-overview">
      <div class="sgrid" id="ovgrid"></div>
      <div class="card ao">
        <div class="ch"><h2>🔥 Hot right now</h2><span class="cbg cbg-o">Priority</span></div>
        <ul class="cl" id="hotlist"></ul>
      </div>
      <div class="g2">
        <div class="card">
          <div class="ch"><h2>This week's top 3</h2></div>
          <ul class="pl">
            <li class="pr"><div class="pnum" style="background:var(--pink-bg);color:var(--pink);">1</div><input type="text" data-key="w_p1" placeholder="Top priority..." /></li>
            <li class="pr"><div class="pnum" style="background:var(--orange-bg);color:var(--orange);">2</div><input type="text" data-key="w_p2" placeholder="Second priority..." /></li>
            <li class="pr"><div class="pnum" style="background:var(--s3);color:var(--muted);">3</div><input type="text" data-key="w_p3" placeholder="Third priority..." /></li>
          </ul>
        </div>
        <div class="card">
          <div class="ch"><h2>Quick notes</h2></div>
          <textarea data-key="ov_notes" style="min-height:110px;" placeholder="Brain dump, reminders, anything..."></textarea>
        </div>
      </div>
    </div>

    <!-- ═ RAPCLASS ════════════════════════════════════════════ -->
    <div class="panel" id="panel-rapclass">
      <div class="card ab">
        <div class="ch"><h2>Platform build</h2><span class="cbg cbg-b">Business</span></div>
        <ul class="cl">
          <li><input type="checkbox" data-key="rc_1"><label>Edit website / app / html / index files</label></li>
          <li><input type="checkbox" data-key="rc_2"><label>Update PDF Workbook design</label></li>
          <li><input type="checkbox" data-key="rc_3"><label>Update GUI — sleek / men-in-black appeal</label></li>
          <li><input type="checkbox" data-key="rc_4"><label>Add Vulnerability Call-to-Action for potential hackers</label></li>
          <li><input type="checkbox" data-key="rc_5"><label>Embed intro video for main framework &amp; lessons</label></li>
          <li><input type="checkbox" data-key="rc_6"><label>Add Google Auth &amp; AI integration when live hosted</label></li>
          <li><input type="checkbox" data-key="rc_7"><label>Make sidebar begin as closed drawer</label></li>
          <li><input type="checkbox" data-key="rc_8"><label>Simplified language across entire structure<span class="note">Accessibility &amp; clarity</span></label></li>
          <li><input type="checkbox" data-key="rc_9"><label>Quiz-like gated structure on all Worksheets &amp; Guides</label></li>
          <li><input type="checkbox" data-key="rc_10"><label>Structure mainframe &amp; curriculum for YouTube channel</label></li>
          <li><input type="checkbox" data-key="rc_11"><label>Film / edit classes</label></li>
          <li><input type="checkbox" data-key="rc_12"><label>Run as local app</label></li>
        </ul>
      </div>
      <div class="g2">
        <div class="card ab">
          <div class="ch"><h2>Test run artists</h2><span class="cbg cbg-b">Beta (3–4)</span></div>
          <ul class="cl">
            <li><input type="checkbox" data-key="rc_hyp"><label>Hyp</label></li>
            <li><input type="checkbox" data-key="rc_tef"><label>Tef</label></li>
            <li><input type="checkbox" data-key="rc_nikki"><label>Nikki</label></li>
            <li><input type="checkbox" data-key="rc_4th"><label>4th artist (TBD)</label></li>
          </ul>
          <div class="fg" style="margin-top:12px;"><div class="fl">Beta notes</div><textarea data-key="rc_beta_notes" placeholder="Feedback, session notes, next steps..."></textarea></div>
        </div>
        <div class="card">
          <div class="ch"><h2>Grants &amp; funding</h2></div>
          <ul class="cl">
            <li><input type="checkbox" data-key="rc_grant_research"><label>Research grant opportunities</label></li>
            <li><input type="checkbox" data-key="rc_grant_apply"><label>Apply for grants</label></li>
            <li><input type="checkbox" data-key="rc_grant_followup"><label>Follow up on applications</label></li>
          </ul>
          <div class="fg" style="margin-top:12px;"><div class="fl">Grant notes</div><textarea data-key="rc_grant_notes" placeholder="Grant names, deadlines, amounts..."></textarea></div>
        </div>
      </div>
