];

const HOT = [
  { key:'rd_carrie',    label:'Film Carrie — Mother\'s Day',       tag:'now' },
  { key:'rd_loralee',   label:'Finish editing Loralee — Mother\'s Day', tag:'now' },
  { key:'emp_tokerfest',label:'TOKERFEST recap — $250',            tag:'now' },
  { key:'rd_kmac',      label:'Finish posting KMAC',               tag:'hot' },
  { key:'pc_mini',      label:'Create Mini-Mgmt pricing card',     tag:'hot' },
  { key:'rc_3',         label:'Update GUI — men-in-black',         tag:'soon' },
  { key:'sg_cover',     label:'Cover art — Same Ol\' G',           tag:'soon' },
  { key:'emp_nakai1',   label:'Mix NAKAI session 1',               tag:'hot' },
];

/* ── Nav ── */
function go(id, silent) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b => b.classList.remove('active'));
  const panel = document.getElementById('panel-' + id);
  if (panel) panel.classList.add('active');
  document.querySelectorAll('.nb').forEach(b => {
    if (b.getAttribute('onclick') === `go('${id}')`) b.classList.add('active');
  });
  const pg = PAGES[id] || {};
  document.getElementById('ptitle').textContent = pg.title || id;
  document.getElementById('psub').textContent = pg.sub || '';
  if (!silent) { const s = load(); s['__page'] = id; save(s); }
}

/* ── Sidebar ── */
function toggleSB() {
  const sb = document.getElementById('sidebar');
  sb.classList.toggle('closed');
  const s = load(); s['__sb'] = sb.classList.contains('closed'); save(s);
}

/* ── Save flash ── */
let ft;
function flash() {
  const el = document.getElementById('saveflash');
  if (el) { el.style.opacity = '1'; clearTimeout(ft); ft = setTimeout(() => el.style.opacity = '0', 1800); }
}

function abtRecalc() {
  const g = k => parseFloat(document.querySelector(`[data-key="${k}"]`)?.value) || 0;
  const prod = g("abt_clothing") + g("abt_video") + g("abt_dancer") + g("abt_feature") + g("abt_cover");
  const party = g("abt_studio") + g("abt_food") + g("abt_sticker") + g("abt_flyers");
  const total = prod + party;
  const fmt = n => "$" + n.toLocaleString();
  const el1 = document.getElementById("abt-prod-total");
  const el2 = document.getElementById("abt-party-total");
  const el3 = document.getElementById("abt-grand-total");
  if (el1) el1.textContent = fmt(prod);
  if (el2) el2.textContent = fmt(party);
  if (el3) el3.textContent = fmt(total);
}

function updateIcBar(val) {
  const raised = Math.max(0, parseFloat(val) || 0);
  const pct = Math.min(100, (raised / 1500) * 100);
  const bar = document.getElementById('icbar');
  if (bar) bar.style.width = pct + '%';
  const lbl = document.getElementById('ic-raised-lbl');
  if (lbl) lbl.textContent = '$' + raised.toLocaleString() + ' raised';
}

/* ── Persist ── */
function persistEl(el) {
  const key = el.dataset.key; if (!key) return;
  const s = load();
  s[key] = el.type === 'checkbox' ? el.checked : el.value;
  save(s); flash(); updateCounts(); updateDashboard();
}

function restoreAll() {
  const s = load();
  document.querySelectorAll('[data-key]').forEach(el => {
    const v = s[el.dataset.key]; if (v === undefined) return;
    if (el.type === 'checkbox') {
      el.checked = !!v;
      const li = el.closest('li');
      if (li && !!v) li.classList.add('done');
    } else { el.value = v; }
  });
  ['sgrec','sgvid','sgbrand'].forEach(k => {
    const el = document.getElementById('pct-' + k);
    if (el) { const colors = {sgrec:'var(--purple)',sgvid:'var(--blue)',sgbrand:'var(--pink)'}; bar(k, el.value, colors[k]); }
  });
  // restore insider circle bar
  if (s["ic_raised"] !== undefined) updateIcBar(s["ic_raised"]);
  setTimeout(abtRecalc, 50); // recalc budget totals after DOM restore
  if (s['__sb'] !== false && s['__sb'] !== undefined) {
    if (!s['__sb']) document.getElementById('sidebar').classList.remove('closed');
  }
  go(s['__page'] || 'overview', true);
}

function attachListeners() {
  document.querySelectorAll('[data-key]').forEach(el => {
    const evt = el.type === 'checkbox' ? 'change' : 'input';
    el.addEventListener(evt, () => persistEl(el));
    if (el.type === 'checkbox') {
      el.addEventListener('change', () => {
        const li = el.closest('li');
        if (li) li.classList.toggle('done', el.checked);
      });
    }
  });
}

/* ── Progress bars ── */
function bar(id, val, color) {
  const pct = Math.min(100, Math.max(0, parseInt(val)||0));
  const el = document.getElementById('bar-' + id);
  if (el) { el.style.width = pct + '%'; if (color) el.style.background = color; }
}

/* ── Counts ── */
function updateCounts() {
  const s = load();
  SECTIONS.forEach(sec => {
    const done = sec.keys.filter(k => !!s[k]).length;
    const rem = sec.keys.length - done;
    const el = document.getElementById('cnt-' + sec.id);
    if (!el) return;
    el.textContent = rem > 0 ? rem : '✓';
    el.style.opacity = rem > 0 ? '1' : '0.5';
  });
}

/* ── Dashboard ── */
function updateDashboard() {
  const s = load();
  const grid = document.getElementById('ovgrid');
  if (grid) {
    grid.innerHTML = SECTIONS.map(sec => {
      const done = sec.keys.filter(k => !!s[k]).length;
      const total = sec.keys.length;
      const pct = total ? Math.round((done/total)*100) : 0;
      return `<div class="sc">
        <div class="sclb" style="color:${sec.color}">${sec.label}</div>
        <div class="scdn">${done}<span style="font-size:14px;color:var(--muted);font-weight:400;"> / ${total}</span></div>
        <div class="sctt">${pct}% complete</div>
        <div class="scbar"><div class="scfill" style="width:${pct}%;background:${sec.color}"></div></div>
      </div>`;
    }).join('');
  }
  const hl = document.getElementById('hotlist');
  if (hl) {
    hl.innerHTML = HOT.map(item => {
      const done = !!s[item.key];
      const tc = item.tag==='now'?'ptag-n':item.tag==='hot'?'ptag-h':'ptag-s';
      const tl = item.tag==='now'?'🔥 now':item.tag==='hot'?'urgent':'soon';
      return `<li class="${done?'done':''}">
        <input type="checkbox" ${done?'checked':''} onchange="syncHot('${item.key}',this)">
        <label>${item.label}</label>
        <span class="ptag ${tc}">${tl}</span>
      </li>`;
    }).join('');
  }
}

function syncHot(key, cb) {
  const s = load(); s[key] = cb.checked; save(s); flash();
  const real = document.querySelector(`[data-key="${key}"]`);
  if (real) {
    real.checked = cb.checked;
    const li = real.closest('li');
    if (li) li.classList.toggle('done', cb.checked);
  }
  updateCounts(); updateDashboard();
}

/* ── Week strip ── */
function getMon(d) { const dt = new Date(d), day = dt.getDay(); dt.setDate(dt.getDate()-((day+6)%7)); dt.setHours(0,0,0,0); return dt; }
function isNellieWeek(mon) { const ref = new Date('2026-04-13'); return Math.round((mon-ref)/604800000)%2===0; }

function renderStrip() {
  const today = new Date(), mon = getMon(today), nel = isNellieWeek(mon);
  const names = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  document.getElementById('wstrip').innerHTML = names.map((n,i) => {
    const d = new Date(mon); d.setDate(mon.getDate()+i);
    const isT = d.toDateString()===today.toDateString(), isW = i>=5, isN = nel&&isW;
    let cls='wd'; if(isT) cls+=' today'; if(isN) cls+=' nellie';
    const tc = isN?'tn':isW?'to':'tw', tl = isN?'Nellie':isW?'off':'work';
    return `<div class="${cls}"><div class="wdn">${n}</div><div class="wdnum">${d.getDate()}</div><div class="wdtag ${tc}">${tl}</div></div>`;
  }).join('');
  const ws = mon.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  const we = new Date(mon); we.setDate(mon.getDate()+6);
  document.getElementById('wklabel').textContent = `Week of ${ws} – ${we.toLocaleDateString('en-US',{month:'short',day:'numeric'})}`;
  const nel2 = isNellieWeek(mon);
  document.getElementById('npillwrap').innerHTML = nel2
    ? '<div class="npill" style="background:var(--yellow-bg);color:var(--yellow);">&#9733; Nellie weekend</div>'
    : '<div class="npill" style="background:var(--s3);color:var(--muted);">Free weekend</div>';
}

/* ── Date clock ── */
function renderDate() {
  document.getElementById('datedisp').innerHTML =
    new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'}) +
    '<br>' + new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
}

