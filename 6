function renderWeeklyDays() {
  document.getElementById('wkdays').innerHTML = SCHED.map(s => `
    <div class="db">
      <h3>${s.day}${s.note?` <span style="font-size:9px;font-weight:400;color:var(--muted);text-transform:none;">(${s.note})</span>`:''}</h3>
      <div class="chips">${s.chips.map(c=>`<span class="chip ${c.c}">${c.l}</span>`).join('')}</div>
      <div class="fg"><div class="fl">Focus notes</div><textarea data-key="wk_${s.day.toLowerCase()}" placeholder="Lock in on ${s.day}..."></textarea></div>
    </div>`).join('');
}

/* ── Reset ── */
function resetAll() {
  if (!confirm('Reset ALL saved data? This cannot be undone.')) return;
  localStorage.removeItem(SK); location.reload();
}

/* ── INIT ── */
document.addEventListener('DOMContentLoaded', () => {
  renderDate();
  renderStrip();
  renderWeeklyDays();
  restoreAll();
  attachListeners();
  // attach weekly day textareas (rendered after DOMContentLoaded)
  document.querySelectorAll('#wkdays [data-key]').forEach(el => {
    el.addEventListener('input', () => persistEl(el));
  });
  updateCounts();
  updateDashboard();
  setInterval(renderDate, 60000);
});
</script>
